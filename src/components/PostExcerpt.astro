---
import type { Post } from '../lib/posts';
import { postUrl, formatMonth } from '../lib/posts';

interface Props { post: Post }
const { post } = Astro.props;
---

<article class="excerpt">
  <p class="meta">
    <a class="tag-pill" href={`/posts/category/${post.data.category}/`}>{post.data.category}</a>
    <time datetime={post.data.date.toISOString()}>{formatMonth(post.data.date)}</time>
  </p>
  <h3><a href={postUrl(post)}>{post.data.title}</a></h3>
  {post.data.description && <p class="desc">{post.data.description}</p>}
</article>

<style>
  .excerpt { padding: 1.35rem 0; border-top: 1px solid var(--line); }
  .meta { display: flex; align-items: baseline; gap: 0.75rem; margin: 0 0 0.3rem; }
  .meta time { color: var(--ink-2); font-size: 0.8rem; font-variant-numeric: tabular-nums; }
  h3 { font-size: 1.12rem; margin: 0 0 0.25rem; }
  h3 a { color: var(--ink); }
  h3 a:hover { color: var(--accent); text-decoration: none; }
  .desc {
    color: var(--ink-2);
    font-size: 0.9rem;
    line-height: 1.8;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
