---
import Base from '../layouts/Base.astro';
import PostExcerpt from '../components/PostExcerpt.astro';
import { getAllPosts, postUrl, formatMonth } from '../lib/posts';
import { featuredIds } from '../data/featured';
import { projects } from '../data/projects';

const all = (await getAllPosts()).filter((p) => !p.data.draft);
const featured = featuredIds
  .map((id) => all.find((p) => p.id === id))
  .filter((p) => p !== undefined);
const [lead, ...minor] = featured;
const featuredSet = new Set(featured.map((p) => p.id));
const latest = all.filter((p) => !featuredSet.has(p.id)).slice(0, 6);
const strip = projects.slice(0, 5);
---

<Base>
  <section class="identity">
    <img src="/assets/img/avatar.png" alt="ChiChieh Huang 的照片" width="72" height="72" />
    <div>
      <p class="who">琪婕 ChiChieh Huang — 專注於 Generative AI 產品開發，用中文把 AI 寫得更清楚。</p>
      <p class="links">
        LLM・Agent・MCP ·
        <a href="https://github.com/wsxqaza12">GitHub</a> ·
        <a href="https://www.linkedin.com/in/chichieh-huang-5322881ba/">LinkedIn</a> ·
        <a href="/rss.xml">RSS</a>
      </p>
    </div>
  </section>

  {lead && (
    <>
      <div class="sec-label">精選</div>
      <div class="featured">
        <a class:list={['lead-card', { 'has-img': !!lead.data.hero }]} href={postUrl(lead)}>
          <div class="lead-body">
            <p class="meta">
              <span class="tag-pill">{lead.data.category}</span>
              <time datetime={lead.data.date.toISOString()}>{formatMonth(lead.data.date)}</time>
            </p>
            <h2>{lead.data.title}</h2>
            <p class="desc">{lead.data.description}</p>
            <span class="read">閱讀全文 →</span>
          </div>
          {lead.data.hero && <img class="lead-img" src={lead.data.hero} alt="" loading="eager" />}
        </a>
        <div class="minor">
          {minor.map((post) => (
            <a class="minor-card" href={postUrl(post)}>
              {post.data.hero && <img src={post.data.hero} alt="" loading="lazy" />}
              <div class="minor-body">
                <p class="meta">
                  <span class="tag-pill">{post.data.category}</span>
                  <time datetime={post.data.date.toISOString()}>{formatMonth(post.data.date)}</time>
                </p>
                <h3>{post.data.title}</h3>
              </div>
            </a>
          ))}
        </div>
      </div>
    </>
  )}

  <div class="cols">
    <section>
      <div class="sec-label">最新文章</div>
      {latest.map((post) => <PostExcerpt post={post} />)}
      <p class="more"><a href="/posts/">所有文章 →</a></p>
    </section>
  </div>

  <section class="proj-strip">
    <span class="sec-label">專案</span>
    <span class="names">
      {strip.map((p, i) => (
        <>
          {i > 0 && <span class="dot">·</span>}
          {p.link ? <a href={p.link}>{p.name}</a> : <a href="/projects/">{p.name}</a>}
        </>
      ))}
      <a class="more-link" href="/projects/">全部 →</a>
    </span>
  </section>
</Base>

<style>
  .identity { display: flex; align-items: center; gap: 1.1rem; margin: 0.5rem 0 2.25rem; }
  .identity img { border-radius: 50%; border: 1px solid var(--line); object-fit: cover; flex-shrink: 0; }
  .who { font-family: var(--serif); font-weight: 600; font-size: 1.15rem; line-height: 1.7; margin: 0; }
  .links { color: var(--ink-2); font-size: 0.87rem; margin: 0.15rem 0 0; }

  .featured { display: grid; grid-template-columns: 1.25fr 1fr; gap: 1rem; margin-top: 0.75rem; }
  @media (max-width: 720px) { .featured { grid-template-columns: 1fr; } }

  .meta { display: flex; align-items: baseline; gap: 0.75rem; margin: 0 0 0.4rem; }
  .meta time { color: var(--ink-2); font-size: 0.8rem; font-variant-numeric: tabular-nums; }

  .lead-card {
    border: 1px solid var(--line);
    border-radius: 12px;
    overflow: hidden;
    color: var(--ink);
    display: grid;
    grid-template-columns: 1fr;
    background:
      radial-gradient(circle at 100% 0%, color-mix(in srgb, var(--accent) 7%, transparent), transparent 55%);
  }
  .lead-card.has-img { grid-template-columns: 1.25fr 1fr; }
  .lead-body { padding: 1.75rem 1.9rem; display: flex; flex-direction: column; }
  .lead-img { width: 100%; height: 100%; object-fit: cover; display: block; }
  @media (max-width: 720px) {
    .lead-card.has-img { grid-template-columns: 1fr; }
    .lead-img { order: -1; aspect-ratio: 21 / 9; height: auto; }
  }
  .lead-card:hover { text-decoration: none; border-color: var(--accent); }
  .lead-card h2 { font-size: 1.45rem; line-height: 1.5; margin: 0 0 0.6rem; }
  .lead-card:hover h2 { color: var(--accent); }
  .lead-card .desc {
    color: var(--ink-2); font-size: 0.92rem; line-height: 1.85; margin: 0;
    display: -webkit-box; -webkit-line-clamp: 4; -webkit-box-orient: vertical; overflow: hidden;
  }
  .lead-card .read { margin-top: auto; padding-top: 1rem; color: var(--accent); font-size: 0.88rem; }
  .lead-card .meta { display: flex; align-items: baseline; gap: 0.75rem; margin: 0 0 0.4rem; }

  .minor { display: flex; flex-direction: column; gap: 1rem; }
  .minor-card {
    border: 1px solid var(--line);
    border-radius: 12px;
    overflow: hidden;
    color: var(--ink);
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .minor-card:hover { text-decoration: none; border-color: var(--accent); }
  .minor-card:hover h3 { color: var(--accent); }
  .minor-card img { width: 100%; aspect-ratio: 21 / 9; object-fit: cover; display: block; }
  .minor-body { padding: 0.9rem 1.2rem 1.1rem; }
  .minor-card h3 { font-size: 1.02rem; line-height: 1.55; margin: 0; }

  .cols { margin-top: 1.5rem; }
  .more { margin: 1rem 0 0; font-size: 0.9rem; }

  .proj-strip {
    display: flex; align-items: baseline; gap: 1.25rem; flex-wrap: wrap;
    border-top: 1px solid var(--line);
    margin-top: 2.5rem; padding-top: 0.5rem;
  }
  .proj-strip .names { font-size: 0.92rem; display: flex; gap: 0.6rem; flex-wrap: wrap; align-items: baseline; }
  .proj-strip a { color: var(--ink); }
  .proj-strip a:hover { color: var(--accent); text-decoration: none; }
  .proj-strip .dot { color: var(--ink-2); }
  .proj-strip .more-link { color: var(--accent); margin-left: 0.5rem; }
</style>
